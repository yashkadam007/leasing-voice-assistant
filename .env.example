# Runtime
APP_ENV=local
LOG_LEVEL=INFO

# FastAPI
API_HOST=127.0.0.1
API_PORT=8000

# LiveKit worker configuration for later SIP milestones.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Contextual acknowledgments are disabled until provider-backed call validation.
ACKNOWLEDGMENT_MODE=disabled
ACKNOWLEDGMENT_DELAY_MS=750
ACKNOWLEDGMENT_CALL_LIMIT=2

# Planned provider defaults for later milestones.
STT_PROVIDER=deepgram
TTS_PROVIDER=deepgram
LLM_PROVIDER=openrouter
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# To test direct OpenAI instead:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
